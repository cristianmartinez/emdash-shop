---
import { getEmDashEntry, getSeoMeta } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/404");

const { entry: product, cacheHint } = await getEmDashEntry("products", slug);

if (!product) return Astro.redirect("/404");

Astro.cache.set(cacheHint);

const seo = getSeoMeta(product, {
	siteTitle: "EmDash Shop",
	siteUrl: Astro.url.origin,
	path: `/shop/${slug}`,
});

function formatPrice(cents: number, currency: string = "USD"): string {
	return new Intl.NumberFormat("en-US", { style: "currency", currency }).format(cents / 100);
}

const variants = (product.data.variants as any[]) ?? [];
const attributes = (product.data.attributes as Record<string, string>) ?? {};
const currency = (product.data.currency as string) || "USD";
---

<Base
	title={seo.title}
	description={seo.description}
	canonical={seo.canonical}
	content={{ collection: "products", id: product.data.id, slug }}
>
	<div class="grid grid-cols-1 gap-12 md:grid-cols-2">
		<!-- Product Image -->
		<div>
			{product.data.featured_image ? (
				<div {...product.edit.featured_image} class="overflow-hidden rounded-xl bg-gray-100">
					<Image image={product.data.featured_image} class="w-full" />
				</div>
			) : (
				<div class="flex aspect-square items-center justify-center rounded-xl bg-gray-100 text-gray-300">
					<svg class="h-24 w-24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
				</div>
			)}
		</div>

		<!-- Product Info -->
		<div class="flex flex-col">
			<h1 {...product.edit.title} class="text-3xl font-bold tracking-tight">{product.data.title}</h1>

			{product.data.description && (
				<p {...product.edit.description} class="mt-2 text-gray-500">{product.data.description}</p>
			)}

			<div {...product.edit.price} class="mt-4 flex items-baseline gap-3">
				<span class="text-3xl font-bold">
					{formatPrice(product.data.price, currency)}
				</span>
				{product.data.compare_at_price && product.data.compare_at_price > product.data.price && (
					<span class="text-lg text-gray-400 line-through">
						{formatPrice(product.data.compare_at_price, currency)}
					</span>
				)}
			</div>

			{product.data.track_inventory && (
				<p class={`mt-2 text-sm ${(product.data.stock_quantity ?? 0) > 0 ? "text-green-600" : "text-red-500"}`}>
					{(product.data.stock_quantity ?? 0) > 0
						? `${product.data.stock_quantity} in stock`
						: "Out of stock"}
				</p>
			)}

			{/* Variant selector */}
			{variants.length > 0 && (
				<div class="mt-6">
					<label class="block text-sm font-medium text-gray-700">Variant</label>
					<select
						id="variant-select"
						data-variants={JSON.stringify(variants)}
						class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
					>
						{variants.map((v: any) => (
							<option value={v.sku}>
								{v.name} — {formatPrice(v.price, currency)}
							</option>
						))}
					</select>
				</div>
			)}

			<!-- Add to Cart -->
			<button
				data-add-to-cart={product.data.id}
				data-variant-sku={variants.length > 0 ? variants[0].sku : undefined}
				class="mt-6 w-full rounded-lg bg-gray-900 px-6 py-3 text-sm font-medium text-white transition hover:bg-gray-800 disabled:cursor-not-allowed disabled:bg-gray-300"
				disabled={product.data.track_inventory && (product.data.stock_quantity ?? 0) <= 0}
			>
				{product.data.track_inventory && (product.data.stock_quantity ?? 0) <= 0
					? "Out of Stock"
					: "Add to Cart"}
			</button>

			{/* Attributes */}
			{Object.keys(attributes).length > 0 && (
				<div class="mt-8 border-t border-gray-200 pt-6">
					<h3 class="text-sm font-medium text-gray-900">Details</h3>
					<dl class="mt-3 space-y-2">
						{Object.entries(attributes).map(([key, value]) => (
							<div class="flex justify-between text-sm">
								<dt class="capitalize text-gray-500">{key}</dt>
								<dd class="font-medium text-gray-900">{value}</dd>
							</div>
						))}
					</dl>
				</div>
			)}
		</div>
	</div>

	<!-- Full Description -->
	{product.data.content && (
		<div {...product.edit.content} class="prose prose-gray mx-auto mt-16 max-w-3xl">
			<h2>Description</h2>
			<PortableText value={product.data.content} />
		</div>
	)}
</Base>

<script>
	import { addToCart } from "@emdash-cms/plugin-commerce/client";

	document.querySelectorAll<HTMLElement>("[data-add-to-cart]").forEach((button) => {
		button.addEventListener("click", async () => {
			const productId = button.dataset.addToCart!;
			const variantSku = button.dataset.variantSku || undefined;

			try {
				await addToCart(productId, variantSku);
				button.textContent = "Added!";
				setTimeout(() => { button.textContent = "Add to Cart"; }, 2000);
			} catch (err) {
				console.error("Failed to add to cart:", err);
			}
		});
	});

	const select = document.getElementById("variant-select") as HTMLSelectElement | null;
	if (select) {
		select.addEventListener("change", () => {
			const button = document.querySelector<HTMLElement>("[data-add-to-cart]");
			if (button) button.dataset.variantSku = select.value;
		});
	}
</script>
