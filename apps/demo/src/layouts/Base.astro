---
import { getMenu } from "emdash";
import {
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import LiveSearch from "emdash/ui/search";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string | null;
	image?: string | null;
	canonical?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const { title, description, image, canonical, content } = Astro.props;

const menu = await getMenu("primary");

const pageCtx = createPublicPageContext({
	Astro,
	kind: content ? "content" : "custom",
	pageType: "website",
	title,
	description,
	canonical,
	image,
	content,
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{canonical && <link rel="canonical" href={canonical} />}
		<EmDashHead page={pageCtx} />
	</head>
	<body class="bg-white text-gray-900 antialiased">
		<EmDashBodyStart page={pageCtx} />

		<header class="border-b border-gray-200">
			<nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
				<a href="/" class="text-xl font-bold tracking-tight">EmDash Shop</a>
				<div class="flex items-center gap-6">
					{
						menu?.items.map((item) => (
							<a href={item.url} target={item.target} class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">
								{item.label}
							</a>
						))
					}
					<LiveSearch placeholder="Search..." collections={["posts", "pages", "products"]} />
				</div>
			</nav>
		</header>

		<main class="mx-auto max-w-6xl px-6 py-10">
			<slot />
		</main>

		<footer class="mt-20 border-t border-gray-200 bg-gray-950 text-gray-400">
			<div class="mx-auto max-w-6xl px-6 py-16">
				<div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
					<!-- Brand -->
					<div class="lg:col-span-1">
						<a href="/" class="text-xl font-bold text-white">EmDash Shop</a>
						<p class="mt-3 text-sm leading-relaxed">Curated products, crafted with care. Powered by EmDash CMS.</p>
					</div>

					<!-- Shop -->
					<div>
						<h4 class="text-sm font-semibold uppercase tracking-wider text-white">Shop</h4>
						<ul class="mt-4 space-y-2.5 text-sm">
							<li><a href="/shop" class="transition hover:text-white">All Products</a></li>
							<li><a href="/shop" class="transition hover:text-white">New Arrivals</a></li>
							<li><a href="/shop" class="transition hover:text-white">Best Sellers</a></li>
						</ul>
					</div>

					<!-- Company -->
					<div>
						<h4 class="text-sm font-semibold uppercase tracking-wider text-white">Company</h4>
						<ul class="mt-4 space-y-2.5 text-sm">
							<li><a href="/about" class="transition hover:text-white">About</a></li>
							<li><a href="/posts" class="transition hover:text-white">Blog</a></li>
						</ul>
					</div>

					<!-- Newsletter / Connect -->
					<div>
						<h4 class="text-sm font-semibold uppercase tracking-wider text-white">Stay in touch</h4>
						<p class="mt-4 text-sm">Get updates on new products and sales.</p>
						<form class="mt-3 flex gap-2" onsubmit="return false;">
							<input type="email" placeholder="you@example.com" class="w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-white placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" />
							<button type="submit" class="shrink-0 rounded-lg bg-white px-4 py-2 text-sm font-medium text-gray-900 transition hover:bg-gray-200">Subscribe</button>
						</form>
					</div>
				</div>

				<div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-gray-800 pt-8 sm:flex-row">
					<p class="text-xs">&copy; {new Date().getFullYear()} EmDash Shop. All rights reserved.</p>
					<p class="text-xs">Built with <a href="https://emdashcms.com" class="text-gray-300 underline underline-offset-2 transition hover:text-white">EmDash CMS</a></p>
				</div>
			</div>
		</footer>

		<EmDashBodyEnd page={pageCtx} />
	</body>
</html>
